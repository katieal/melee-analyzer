{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snhmelee.com/schemas/bracket",
  "title": "Melee Bracket",
  "description": "A bracket for a Super Smash Bros Melee tournament",
  "type": "object",
  "properties": {
    "name": {
      "description": "The name of the tournament",
      "type": "string"
    },
    "date": {
      "description": "Date the tournament took place",
      "type": "string",
      "format": "date"
    },
    "location": {
      "description": "Tournament location",
      "type": "string"
    },
    "mode": {
      "description": "Bracket elimination mode",
      "type": "string",
      "enum": ["Single Elim", "Double Elim"]
    },
    "theme": {
      "description": "Tournament theme",
      "type": "string",
      "enum": ["Normal", "Reverse Mains", "Random", "Other"]
    },
    "winner": { "type": "string"},
    "matches": {
      "type": "array",
      "$ref": "https://snhmelee.com/schemas/match"
    }
  }
}